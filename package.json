{
  "name": "nodegraph",
  "version": "0.1.0",
  "description": "Semantic relationship graph primitives extracted from NodeRoom.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HomenShum/NodeGraph.git"
  },
  "bugs": {
    "url": "https://github.com/HomenShum/NodeGraph/issues"
  },
  "homepage": "https://github.com/HomenShum/NodeGraph#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "example:build": "vite build examples/showcase --outDir ../../dist-showcase --emptyOutDir",
    "example:dev": "vite examples/showcase --host 127.0.0.1 --port 5174",
    "showcase:capture": "node scripts/capture-showcase.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.511.0"
  },
  "devDependencies": {
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.0",
    "@xyflow/react": "^12.11.0",
    "playwright": "^1.56.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@types/react": "^19.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.3.0",
    "vitest": "^4.1.10"
  }
}
